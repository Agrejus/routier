{
  "name": "routier-collection",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "core",
    "datastore",
    "react",
    "plugins/*",
    "test-utils",
    "sync-server"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "cd core && npm run tsc",
    "build:routier": "cd routier && npm run tsc",
    "sync:examples": "node scripts/sync-doc-examples.mjs",
    "extract:doc-code": "node scripts/extract-doc-code.mjs",
    "docs:prepare": "npm run extract:doc-code && npm run sync:examples",
    "docs:fix-includes": "node scripts/fix-capture-includes.mjs",
    "bump": "node scripts/bump-version.mjs",
    "benchmark": "cd benchmark && npm run benchmark",
    "benchmark:memory": "cd benchmark && npm run benchmark:memory",
    "typedoc": "typedoc",
    "lint": "npm run lint --workspaces --if-present && oxlint . --ignore-pattern \"docs/**\" --ignore-pattern \"examples/**\" --ignore-pattern \"scripts/**\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/*.spec.*\" --ignore-pattern \"**/*.mjs\"",
    "lint:fix": "oxlint . --fix --fix-suggestions --ignore-pattern \"docs/**\" --ignore-pattern \"examples/**\" --ignore-pattern \"scripts/**\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/*.spec.*\" --ignore-pattern \"**/*.mjs\"",
    "format:oxfmt": "oxfmt .",
    "format:check:oxfmt": "oxfmt . --check",
    "oxfmt": "oxfmt . --check"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.3",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "ts-jest": "^29.1.2",
    "typedoc": "^0.28.14",
    "typedoc-plugin-markdown": "^4.9.0"
  }
}
