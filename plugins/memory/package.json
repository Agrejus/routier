{
  "name": "@routier/memory-plugin",
  "version": "0.2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "source": "./src/index.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:types": "tsc --emitDeclarationOnly",
    "build:bundle": "rspack build",
    "build": "npm run build:bundle && npm run build:types",
    "tsc": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0"
  },
  "sideEffects": false,
  "author": "James DeMeuse <james.demeuse@gmail.com>",
  "license": "MIT",
  "repository": "routier",
  "keywords": [
    "orm",
    "typescript",
    "web",
    "indexeddb",
    "electron",
    "data access layer",
    "entities",
    "entity framework",
    "database"
  ],
  "description": "Memory plugin for routier",
  "peerDependencies": {
    "@routier/core": ">=0.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@routier/core": "^0.2.0",
    "@routier/datastore": "^0.2.0",
    "@routier/test-utils": "file:../../test-utils",
    "@rspack/cli": "^1.1.8",
    "@rspack/core": "^1.1.8",
    "tinybench": "^5.1.0",
    "ts-loader": "^9.5.2"
  }
}
