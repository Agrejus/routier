    "data access layer",
    "entities",
    "entity framework",
    "database",
    "routier"
  ],
  "description": "MySQL plugin for Routier",
  "peerDependencies": {
    "@routier/core": ">=0.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@routier/core": "^0.2.0",
    "@routier/datastore": "^0.2.0",
    "@rspack/cli": "^1.1.8",
    "@rspack/core": "^1.1.8",
    "ts-loader": "^9.5.2"
  },
  "dependencies": {
    "mysql2": "^3.9.0"
  }
